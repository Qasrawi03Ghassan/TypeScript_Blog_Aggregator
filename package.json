  "devDependencies": {
    "@types/node": "^26.1.0",
    "drizzle-kit": "^0.31.10",
    "gitignore": "^0.7.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
