{
  "name": "build_blog_aggregator",
  "version": "1.0.0",
  "description": "This project features an RSS feed aggregator CLI application built using TypeScript and Postgresql.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "tsx ./src/index.ts",
    "db-generate":"npx drizzle-kit generate --config=src/lib/db/Configs/drizzle.config.ts",
    "db-migrate":"npx drizzle-kit migrate --config=src/lib/db/Configs/drizzle.config.ts"
  },
